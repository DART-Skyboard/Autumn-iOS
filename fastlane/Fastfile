default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # API Key for App Store Connect
    api_key = app_store_connect_api_key(
      key_id: "P6Z72KS63T",
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_P6Z72KS63T.p8"
    )

    # Ensure the keychain created by CI is used
    if ENV["KEYCHAIN_PATH"]
      setup_ci(
        provider: "github",
        keychain_password: ENV["KEYCHAIN_PASSWORD"]
      )
    end

    # Build the app using the workspace generated by Tuist
    build_app(
      workspace: "Autumn.xcworkspace",
      scheme: "AutumnApp",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {}, # Let automatic signing handle it if possible, or specify if match is used
        signingStyle: "automatic",
        teamID: "L7AHWS9Q6V"
      },
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath #{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_P6Z72KS63T.p8 -authenticationKeyID P6Z72KS63T -authenticationKeyIssuerID #{ENV["ASC_ISSUER_ID"]}"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
