default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "P6Z72KS63T",
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "#{ENV["HOME"]}/.appstoreconnect/private_keys/AuthKey_P6Z72KS63T.p8"
    )

    build_app(
      project: "Package.swift",
      scheme: "AutumnApp",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "L7AHWS9Q6V",
        bundleID: "DART-Meadow-LLC.Autumn"
      },
      xcargs: "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=L7AHWS9Q6V PRODUCT_BUNDLE_IDENTIFIER=DART-Meadow-LLC.Autumn INFOPLIST_FILE=Sources/AutumnApp/Info.plist",
      allow_provisioning_updates: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
